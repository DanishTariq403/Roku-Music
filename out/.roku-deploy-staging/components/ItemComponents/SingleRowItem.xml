        <Label id="subtitle" translation="[0,298]" width="262" height="24" vertAlign="top" horizAlign="left" wrap="true" maxLines="1" color="#AAAAAA" visible="false">
            <Font role="font" uri="pkg:/components/Fonts/Inter-Regular.otf" size="16" />
