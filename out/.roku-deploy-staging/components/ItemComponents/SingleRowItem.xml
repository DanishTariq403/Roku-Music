        <EmojiLabel id="moodEmoji" translation="[119,40]" width="40" height="40" horizAlign="center" vertAlign="center" emojiSize="32" visible="false" />

        <Poster id="overlay" translation="[0,0]" width="262" height="262" uri="" visible="false" />

