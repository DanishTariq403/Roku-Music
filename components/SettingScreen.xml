<component name="SettingScreen" extends="Group" initialFocus="videosList">
  <script type="text/brightscript" uri="SettingScreen.brs" />
  <script type="text/brightscript" uri="pkg:/components/Navbar.brs" />
  <script type="text/brightscript" uri="pkg:/components/ItemComponents/SingleRowItemLayout.brs" />
  <script type="text/brightscript" uri="pkg:/components/ItemComponents/ExploreRowItemLayout.brs" />

  <interface>
    <field id="isTrialExpired" type="boolean" onChange="showSubPopup" />
  </interface>

  <children>
    <Poster translation="[0,0]" width="1920" height="1080" uri="pkg:/images/BG.png" />

    <Label id="screenTitle"
      translation="[161,48]"
      width="600"
      height="48"
      text="Explore"
      color="#FFFFFF">
      <Font role="font" uri="pkg:/components/Fonts/Inter-Bold.otf" size="32" />
    </Label>

    <BusySpinner id="spinner" translation="[896,476]"  />

    <RowList id="videosList"
      itemComponentName="ExploreRowItem"
      translation="[161,110]"
      itemSpacing="[27,44]"
      itemSize="[1759,410]"
      rowLabelOffset="[[5,20]]"
      showRowLabel="true"
      rowLabelColor="#FFFFFF"
      numRows="8"
      rowFocusAnimationStyle="fixedFocus"
      vertFocusAnimationStyle="fixedFocus"
      drawFocusFeedback="false">
      <Font role="rowLabelFont" uri="pkg:/components/Fonts/Inter-Bold.otf" size="28" />
    </RowList>

    <Poster id="blurOL" uri="pkg:/images/blurOL.png" width="1920" height="1080" translation="[0,0]" visible="false" />

    <Navbar id="navbar" />
  </children>
</component>
