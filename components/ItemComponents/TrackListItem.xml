<component name="TrackListItem" extends="Group">
    <script type="text/brightscript" uri="TrackListItem.brs" />
    <interface>
        <field id="itemContent" type="node" onChange="onItemContent" />
        <field id="focusPercent" type="float" onChange="onFocusChange" />
        <field id="gridHasFocus" type="boolean" onChange="onFocusChange" />
    </interface>
    <children>
        <Poster id="rowBg" uri="pkg:/images/" width="1850" height="104" translation="[0,0]" />
        <Label id="indexLabel" translation="[0,39]" width="80" height="26" horizAlign="center" vertAlign="center" color="#888888">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Regular.ttf" size="22" />
        </Label>
        <Poster id="playIcon" uri="pkg:/images/playTrue.png" translation="[0,39]" width="80" height="26" visible="false" />
        <Poster id="favIcon" uri="pkg:/images/favFalse.png" translation="[1765,39]" width="80" height="28"  />
        <Poster id="thumbnailPoster" loadDisplayMode="scaleToZoom" translation="[80,16]" width="72" height="72" />
        <Label id="videoTitle" translation="[168,22.5]" width="900" height="31" vertAlign="center" horizAlign="left" color="#FFFFFF" maxLines="1">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Bold.ttf" size="26" />
        </Label>
        <Label id="artistLabel" translation="[168,57.5]" width="900" height="24" vertAlign="center" horizAlign="left" color="#888888" maxLines="1">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Regular.ttf" size="20" />
        </Label>
        <Label id="durationLabel" translation="[1499,39]" width="250" height="26" horizAlign="right" vertAlign="center" color="#888888">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Regular.ttf" size="22" />
        </Label>
    </children>
</component>
