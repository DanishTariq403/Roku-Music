<component name="SearchKeywordItem" extends="Group">
    <script type="text/brightscript" uri="SearchKeywordItem.brs" />
    <interface>
        <field id="itemContent" type="node" onChange="onItemContent" />
        <field id="focusPercent" type="float" onChange="changeFocus" />
        <field id="gridHasFocus" type="boolean" onChange="changeFocus" />
        <field id="rowHasFocus" type="boolean" onChange="changeFocus" />
    </interface>
    <children>
        <Rectangle id="bg" translation="[8,8]" color="0x2A2A2AFF" width="134" height="50" />
        <Poster id="focus" translation="[0,0]" width="150" height="64" uri="pkg:/images/keywordFocus.png" visible="false" />
        <Label id="label" translation="[20,8]" width="126" height="50" horizAlign="center" vertAlign="center" color="#FFFFFF" wrap="false" maxLines="1">
            <Font role="font" uri="pkg:/components/Fonts/Inter-Regular.otf" size="18" />
        </Label>
    </children>
</component>
