<component name="FavoriteScreen" extends="Group" initialFocus="videosList" >
    <script type="text/brightscript" uri="FaveScreen.brs" />
        <script type="text/brightscript" uri="Navbar.brs" />

    <interface>
                <field id="btnBackSelected" alias="btnNoFav.buttonSelected" type="integer" />
                <field id="isTrialExpired" type="boolean" onChange="showSubPopup" />
                

        
    </interface>
    <children>
     <Poster translation="[0,0]" width="1920" height="1080" uri="pkg:/images/BG.png" />

     <Button id="btnBack" focusable="true" iconUri=""
                text="" focusedIconUri="" visible="false" translation="[118, 56]"
                maxWidth="119" minWidth="119" height="60"
                focusBitmapUri="pkg:/images/btnBackF.png"
                focusFootprintBitmapUri="pkg:/images/btnBackUF.png" showFocusFootprint="true" />

<Label id="screenTitle" visible="true" text="Library" translation="[161,50]" width="769" height="48" wrap="true"  maxLines="2" >
                     <Font role="font" uri="pkg:/components/Fonts/Roboto-Regular.ttf" size="32" />

                    </Label>
         <MarkupGrid id="videosList" 
            itemComponentName="SingleRowItem"
            translation="[161,122]"
            itemSpacing="[27,27]"
           itemSize="[278, 278]"
            numColumns="5"
            numRows="3"
            drawFocusFeedback="true"
            vertFocusAnimationStyle="fixedFocus"
            rowFocusAnimationStyle ="fixedFocus"

            focusBitmapUri="pkg:/images/videoF.png"
         />


        <Button id="btnNoFav" visible="false" translation="[682,309]" minWidth="556" maxWidth="556" height="464" iconUri="" focusedIconUri="" focusBitmapUri="pkg:/images/NVF.png" focusfootprintbitmapuri="pkg:/images/NVF.png" showFocusFootprint="true" />
         <Timer id="focusTimer" duration="0.01" repeat="false" />
                    <Poster id="blurOL" uri="pkg:/images/blurOL.png" width="1920" height="1080" translation="[0,0]" visible="false" />

         <Navbar id="navbar" />

    </children>
    
</component>