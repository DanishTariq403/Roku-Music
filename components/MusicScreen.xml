<component name="MusicScreen" extends="Group" initialFocus="btnPlay">
    <script type="text/brightscript" uri="MusicScreen.brs" />

    <interface>
        <field id="selectedTrack" type="node" onChange="onTrackSelected" />
        <field id="relatedContent" type="node" />
        <field id="resumePosition" type="integer" value="0" />
        <field id="isVideoResume" type="boolean" value="false" />
        <field id="saveContinueWatching" type="boolean" value="false" />
        <field id="autoPlayNext" type="boolean" value="false" />
        <field id="playlistTitle" type="string" />
        <field id="playlistThumbnail" type="string" />
        <field id="isTrialExpired" type="boolean" onChange="showSubPopup" />
    </interface>

    <children>
        <Poster id="baseBg" uri="pkg:/images/BG.png" translation="[0,0]" width="1920" height="1080" />
        <Poster id="artistBg" loadDisplayMode="scaleToZoom" translation="[0,0]" width="1920" height="1080" />
        <Rectangle id="bgDim" color="0x000000AA" width="1920" height="1080" translation="[0,0]" />

        <Poster id="headerPlaylistThumb" loadDisplayMode="scaleToZoom" translation="[80,51]" width="40" height="40" />
        <Label id="headerPlaylistTitle" translation="[132,56]" width="500" height="29" horizAlign="left" color="#FFFFFF" maxLines="1">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Bold.ttf" size="24" />
        </Label>

                <Poster translation="[1689,48]" width="151" height="46" uri="pkg:/images/btnUpUF.png" />


        <Button id="btnUpgrade" focusable="true" translation="[1681,40]" height="62" minWidth="167" maxWidth="167"
             iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnUpF.png"
            focusFootprintBitmapUri="pkg:/images/.png" />

        <Group id="musicPlayerGroup" translation="[0,0]">
                    <Poster id="trackThumb" loadDisplayMode="scaleToZoom" translation="[80,561]" width="216" height="216" />

        <Label id="titleName" translation="[328,687]" width="1512" vertalign="center" height="100" color="#FFFFFF" maxLines="2" wrap="true">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-ExtraBold.ttf" size="48" />
        </Label>

        <Label id="creatorName" translation="[328,728]" vertalign="center" width="600" height="29" color="#B3B3B3" maxLines="1">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Medium.ttf" size="24" />
        </Label>

        <Button id="btnSave" focusable="true" translation="[1719,475]" height="46" minWidth="121" maxWidth="121"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsSaveF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsSaveUF.png" />

        <Label id="videoPosition" translation="[80,817]" width="120" height="22" color="#FFFFFF">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Medium.ttf" size="18" />
        </Label>

        <Label id="videoDuration" translation="[1786,817]" width="120" height="28" horizAlign="left" color="#FFFFFF">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Medium.ttf" size="18" />
        </Label>

        <Poster id="durationBar" uri="pkg:/images/durationPoster.png" translation="[154,825]" width="1608" height="6" />
        <Poster id="positionBar" visible="false" uri="pkg:/images/positionBarInit.png" translation="[154,825]" width="0" height="6" />
        <Button id="btnPositionBlob" focusable="true" visible="false" translation="[154,820]" height="16" minWidth="16" maxWidth="16"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="false"
            focusBitmapUri="pkg:/images/positionBlob.png" />

        <Button id="btnShuffle" focusable="true" translation="[80,863]" height="80" minWidth="80" maxWidth="80"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsShuffleF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsShuffleUF.png" />

        <Button id="btnPrev" focusable="true" translation="[160,863]" height="80" minWidth="80" maxWidth="80"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsPrevF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsPrevUF.png" />

        <Button id="btnPlay" focusable="true" translation="[240,863]" height="80" minWidth="80" maxWidth="80"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsPlayF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsPlayUF.png" />

        <Button id="btnNext" focusable="true" translation="[320,863]" height="80" minWidth="80" maxWidth="80"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsNextF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsNextUF.png" />

        <Button id="btnRepeat" focusable="true" translation="[400,863]" height="80" minWidth="80" maxWidth="80"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsRepeatF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsRepeatUF.png" />

        <Button id="btnDarkMode" focusable="true" translation="[1681,834]" height="80" minWidth="159" maxWidth="159"
            text="" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/btnMsDarkF.png"
            focusFootprintBitmapUri="pkg:/images/btnMsDarkUF.png" />

            </Group>

        <Label id="relatedLabel" translation="[80,1003]" width="400" height="32" text="NEXT SONG" color="#FFFFFF">
            <Font role="font" uri="pkg:/components/Fonts/Figtree-Bold.ttf" size="22" />
        </Label>

        <MarkupGrid id="relatedList"
            itemComponentName="RelatedSongItem"
            translation="[80,1052]"
            itemSpacing="[16,0]"
            itemSize="[278,278]"
            numRows="2"
            numColumns="6"
            rowFocusAnimationStyle="fixedFocus"
            vertFocusAnimationStyle="fixedFocus"
            drawFocusFeedback="false"
            focusBitmapUri="pkg:/images/videoF.png" />

        <Timer id="progressTimer" repeat="true" duration="1" />
        <Timer id="videoDurationTimer" repeat="true" duration="1" />
        <Timer id="collapseTimer" repeat="false" duration="3" />
        <BusySpinner id="videospinner" translation="[230,853]" visible="false" />

        <Animation id="playerUpAnim" duration="0.15" repeat="false" easeFunction="easeOut">
            <Vector2DFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[[0.0, 0.0], [0.0, -280.0]]"
                fieldToInterp="musicPlayerGroup.translation" />
            <Vector2DFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[[80.0, 1003.0], [80.0, 683.0]]"
                fieldToInterp="relatedLabel.translation" />
            <Vector2DFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[[80.0, 1052.0], [80.0, 712.0]]"
                fieldToInterp="relatedList.translation" />
        </Animation>

        <Animation id="playerDownAnim" duration="0.15" repeat="false" easeFunction="easeOut">
            <Vector2DFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[[0.0, -280.0], [0.0, 0.0]]"
                fieldToInterp="musicPlayerGroup.translation" />
            <Vector2DFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[[80.0, 683.0], [80.0, 1003.0]]"
                fieldToInterp="relatedLabel.translation" />
            <Vector2DFieldInterpolator
                key="[0.0, 1.0]"
                keyValue="[[80.0, 712.0], [80.0, 1052.0]]"
                fieldToInterp="relatedList.translation" />
        </Animation>

        <Button id="AppLockPopup" translation="[0,0]" height="1080" minWidth="1920" visible="false"
            maxWidth="1920" iconUri="" focusedIconUri="" showFocusFootprint="true"
            focusBitmapUri="pkg:/images/subExpPopup.png"
            focusFootprintBitmapUri="pkg:/images/subExpPopup.png" />
    </children>
</component>
